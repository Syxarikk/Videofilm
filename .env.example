# Скопируйте в .env и заполните своими значениями.
# .env в git НЕ коммитим.

# Случайная строка >= 32 байта (например, openssl rand -hex 32)
SESSION_SECRET=change-me-to-random-64-hex-chars

# SQLite-файл (development)
DATABASE_URL=sqlite:///./app.db

# Куда qBittorrent кладёт файлы (используется в Плане 2; в Плане 1 не используется,
# но конфиг готов сразу).
MEDIA_ROOT=/srv/Общее

# Логин/пароль qBittorrent Web UI (План 2; в Плане 1 не используется).
QBITTORRENT_URL=http://127.0.0.1:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=change-me

# Где ffmpeg создаёт временные HLS-сегменты. По умолчанию — системная temp-папка.
# Для production: /var/lib/mediasrv/hls (создаётся install.sh-ом).
# HLS_WORK_ROOT=/var/lib/mediasrv/hls

# Опционально — авто-метаданные с TMDB.
# Получить ключ: themoviedb.org → Settings → API → API Read Access Token (v4)
TMDB_API_KEY=

# Опционально — fallback на Kinopoisk если TMDB не нашёл.
# Получить ключ: kinopoiskapiunofficial.tech (~500 запросов/день)
KINOPOISK_API_KEY=
